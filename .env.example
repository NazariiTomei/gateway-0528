# Beam node environment (orchestrator, worker, validator)
# Copy to `.env` and adjust. Never commit `.env`.
#
# Public Beam endpoints:
# CORE_SERVER_URL      -> Beam control plane (HTTP)
# ORCH_GATEWAY_URL     -> orchestrator NATS control session (nats:// or tls://)
# WORKER_GATEWAY_URL   -> public worker WebSocket gateway (or your dedicated gateway, see below)

# =============================================================================
# MAINNET
# =============================================================================
CORE_SERVER_URL=https://beamcore.b1m.ai
ORCH_GATEWAY_URL=tls://orch-gateway.b1m.ai:4222
WORKER_GATEWAY_URL=https://public-worker-gateway.b1m.ai

# Region sent to gateway on connect (one of: europe, north-america, asia)
# WORKER_REGION=europe

SUBTENSOR_NETWORK=finney
NETUID=105

# =============================================================================
# WORKER
# =============================================================================
# Set false for bandwidth proof only (no on-chain payment row).
# WORKER_REQUIRED_PAYMENT=true

# =============================================================================
# ORCHESTRATOR
# =============================================================================
WALLET_NAME=orchestrator
WALLET_HOTKEY=default
# WALLET_PATH=~/.bittensor/wallets
# READY=true

# Dedicated worker gateway (recommended for production — see docs/dedicated-worker-gateway.md)
# WORKER_GATEWAY_PUBLIC_URL=https://gateway.firefoxnode.com
# WORKER_GATEWAY_CONTROL_URL=https://gateway.firefoxnode.com
# WORKER_GATEWAY_CONTROL_SECRET=same-secret-as-neurons/worker_gateway/.env

# LOG_LEVEL=INFO

# =============================================================================
# VALIDATOR
# =============================================================================
BEAM_VALIDATOR_WALLET_NAME=validator
BEAM_VALIDATOR_WALLET_HOTKEY=default
# BEAM_VALIDATOR_WALLET_PATH=~/.bittensor/wallets

BEAM_VALIDATOR_CORE_SERVER_URL=https://beamcore.b1m.ai

# BEAM_VALIDATOR_LOG_LEVEL=INFO
