# Orchestrator-only environment.
# Copy to `neurons/orchestrator/.env` or set from your process manager.

CORE_SERVER_URL=https://beamcore.b1m.ai
ORCH_GATEWAY_URL=https://orch-gateway.b1m.ai
SUBTENSOR_NETWORK=finney
NETUID=105

# Dedicated worker gateway (recommended for production)
WORKER_GATEWAY_PUBLIC_URL=https://gateway.firefoxnode.com
# Beam upstream name (same value as WORKER_GATEWAY_PUBLIC_URL):
# ORCHESTRATOR_WORKER_GATEWAY_URL=https://gateway.firefoxnode.com
WORKER_GATEWAY_CONTROL_URL=https://gateway.firefoxnode.com
WORKER_GATEWAY_CONTROL_SECRET=same-secret-as-gateway-.env

# READY=false

WALLET_NAME=orchestrator
WALLET_HOTKEY=default
WALLET_PATH=~/.bittensor/wallets

LOG_LEVEL=INFO
