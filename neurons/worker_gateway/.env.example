# Dedicated worker gateway — copy to .env in this directory
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8001
LOG_LEVEL=INFO

# Public URL workers and BeamCore see (no trailing path)
WORKER_GATEWAY_PUBLIC_URL=https://gateway.firefoxnode.com

# Shared with orchestrator (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
WORKER_GATEWAY_CONTROL_SECRET=change-me-to-a-long-random-secret

GATEWAY_REQUIRE_API_KEY=true

# Worker stats JSON (total_tasks, bytes_relayed, trust_score, …) — survives gateway restart
# WORKER_GATEWAY_METRICS_PATH=./data/worker_metrics.json

# Worker list HTTP API: GET /get-firefox-workers (header x-control-secret)
